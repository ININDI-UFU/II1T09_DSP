Consolas"/></a:rPr><a:t>#define SAMPLES 1024</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>#define SAMPLING_FREQ 10000</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>double vReal[SAMPLES], vImag[SAMPLES];</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>ArduinoFFT&lt;double&gt; FFT(vReal, vImag,</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  SAMPLES, SAMPLING_FREQ);</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:spcBef><a:spcPts val="200"/></a:spcBef><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="55EFC4"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>// 1. Coletar amostras</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>for(int i=0; i&lt;SAMPLES; i++) {</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  vReal[i] = analogRead(34);</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  vImag[i] = 0;</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  delayMicroseconds(100); }</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:spcBef><a:spcPts val="200"/></a:spcBef><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="55EFC4"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>// 2. Janela + FFT + Magnitude</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>FFT.windowing(FFTWindow::Hamming,</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  FFTDirection::Forward);</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>FFT.compute(FFTDirection::Forward);</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>FFT.complexToMagnitude();</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:spcBef><a:spcPts val="200"/></a:spcBef><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="55EFC4"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>// 3. Frequência dominante</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1800" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>double peak = FFT.majorPeak();</a:t></a:r></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="3582902321"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>