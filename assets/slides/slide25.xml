ll><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>double peakFreq = 0; double peakVal = 0;</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>for(int i=1; i&lt;SAMPLES/2; i++) {</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  if(vReal[i] &gt; peakVal) {</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>    peakVal = vReal[i];</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>    peakFreq = i * (SAMPLING_FREQ/SAMPLES);</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>  }</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="1500"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="74B9FF"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>}</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:lnSpc><a:spcPts val="2000"/></a:lnSpc><a:spcBef><a:spcPts val="400"/></a:spcBef><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1600" b="1" dirty="0"><a:solidFill><a:srgbClr val="00CEC9"/>